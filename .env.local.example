# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://pcknshdzygrmpaekgcem.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_QHPs34yORnsLg-ELYX-NTQ_VXreUVaN

# Somente server / Edge Functions — nunca expor no client
SUPABASE_SERVICE_ROLE_KEY=

# Acesso direto ao Postgres (para aplicar migrations e regenerar tipos)
URI=postgresql://postgres:<senha>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_ACCESS_TOKEN=

# Agente de IA (OpenAI)
OPENAI_API_KEY=
# ID do modelo OpenAI (ex.: gpt-4o, gpt-5, o3...). Default: gpt-4o
OPENAI_MODEL=gpt-4o

# Bureau deps.com.br (API Mix V3) — obrigatórias; sem as três o client lança erro
DEPS_API_BASE_URL=https://api-portal.deps.com.br
DEPS_API_EMAIL=
DEPS_API_PASSWORDL=
DEPS_API_CENTRO_CUSTOS=
# Opcional — nome exato do produto na conta deps (default: Smart PF 002 / Smart PJ 010).
# O identificador real (ex: 29375070) é obtido do retorno do login.
DEPS_PRODUTO_PF=Smart PF 002
DEPS_PRODUTO_PJ=Smart PJ 010

# SMTP — autogestão de SCR (envio do termo + código por e-mail). SECRETOS.
SMTP_HOST=                        # ex.: smtp.hostinger.com
SMTP_PORT=465                     # 465 = SSL implícito; 587 = STARTTLS
SMTP_SECURE=true                  # true p/ 465, false p/ 587
SMTP_USER=                        # caixa de envio
SMTP_PASS=                        # SECRETO — senha da caixa
SMTP_FROM=                        # opcional — ex.: Reino do Crédito <contato@dominio.com>

# URL base do app — usada no link do e-mail de autorização SCR
NEXT_PUBLIC_SITE_URL=http://localhost:3000
